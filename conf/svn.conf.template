<VirtualHost *:${SVN_PORT}>
    ServerName localhost

    # ヘルスチェック用エンドポイント（認証不要・静的ファイル）
    Alias /health /var/www/html/health.html
    <Directory /var/www/html>
        Require all granted
        Options None
    </Directory>

    # SVN リポジトリ群のルート
    <Location /svn>
        DAV svn
        SVNParentPath /svn/repos

        AuthType Basic
        AuthName "SVN Repository"
        AuthUserFile /svn/conf/passwd

        Require valid-user

        SVNAutoversioning on
    </Location>

    ErrorLog /dev/stderr
    CustomLog /dev/stdout combined
</VirtualHost>
